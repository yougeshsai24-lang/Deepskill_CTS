using System;

class Calculator
{
    public int Add(int a, int b)
    {
        return a + b;
    }
}

class Program
{
    static void Main()
    {
        Calculator cal = new Calculator();

        Console.WriteLine(cal.Add(2, 3));
        Console.WriteLine(cal.Add(5, 5));
        Console.WriteLine(cal.Add(10, 20));
        Console.WriteLine(cal.Add(15, 25));
    }
}
