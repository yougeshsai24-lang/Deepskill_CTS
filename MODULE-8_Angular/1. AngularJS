# Install Angular CLI
npm install -g @angular/cli

# Create the Angular project
ng new student-course-portal --routing --style=css

# During project creation choose:
# SSR/SSG? -> N
# AI tools? -> None (Press Enter)

# Go to the project folder
cd student-course-portal

# Generate components
ng g c pages/home
ng g c pages/course-list
ng g c pages/student-profile
ng g c components/header

# Run the application
ng serve


http://localhost:4200
