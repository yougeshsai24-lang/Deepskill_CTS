SELECT *
FROM
(
    SELECT ProductID,
           ProductName,
           Category,
           Price,
           ROW_NUMBER() OVER(PARTITION BY Category ORDER BY Price DESC) AS RowNo,
           RANK() OVER(PARTITION BY Category ORDER BY Price DESC) AS RankNo,
           DENSE_RANK() OVER(PARTITION BY Category ORDER BY Price DESC) AS DenseRank
    FROM Products
) AS T
WHERE RowNo <= 3;
