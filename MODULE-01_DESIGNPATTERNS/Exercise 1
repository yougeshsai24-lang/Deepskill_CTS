LOGGER:
class Logger
{
    static Logger obj;

    private Logger()
    {
    }

    static Logger getInstance()
    {
        if(obj == null)
        {
            obj = new Logger();
        }
        return obj;
    }

    void display(String msg)
    {
        System.out.println(msg);
    }
}
